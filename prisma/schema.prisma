// ============================================================
// PRISMA SCHEMA — Enterprise Inventory Management System
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  BANNED
  PENDING_VERIFICATION
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  DRAFT
  ARCHIVED
  PENDING_APPROVAL
}

enum ProductType {
  SIMPLE
  VARIABLE
  BUNDLE
  DIGITAL
  SERVICE
}

enum StockOperationType {
  STOCK_IN
  STOCK_OUT
  ADJUSTMENT
  TRANSFER_IN
  TRANSFER_OUT
  PURCHASE_IN
  SALES_OUT
  RETURN_IN
  RETURN_OUT
  DAMAGE
  EXPIRY
  LOST
  CORRECTION
  INITIAL
}

enum PurchaseOrderStatus {
  DRAFT
  PENDING
  CONFIRMED
  PARTIALLY_RECEIVED
  RECEIVED
  INVOICED
  PAID
  CANCELLED
  RETURNED
}

enum SalesOrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  PACKED
  DISPATCHED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  RETURNED
  REFUNDED
  ON_HOLD
}

enum TransferStatus {
  DRAFT
  PENDING
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

enum ReturnType {
  CUSTOMER_RETURN
  SUPPLIER_RETURN
}

enum ReturnStatus {
  PENDING
  APPROVED
  REJECTED
  PROCESSED
  REFUNDED
}

enum AlertType {
  LOW_STOCK
  OUT_OF_STOCK
  EXPIRY_NEAR
  REORDER_REQUIRED
  DAMAGE_HIGH
  WAREHOUSE_FULL
  PURCHASE_PENDING
}

enum AlertStatus {
  ACTIVE
  ACKNOWLEDGED
  RESOLVED
  DISMISSED
}

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  IMPORT
  APPROVE
  REJECT
  TRANSFER
  ADJUSTMENT
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHEQUE
  UPI
  CREDIT_CARD
  DEBIT_CARD
  NET_BANKING
  WALLET
  COD
  CREDIT_NOTE
}

// ============================================================
// USERS & AUTH
// ============================================================

model User {
  id                String     @id @default(uuid())
  name              String
  email             String     @unique
  phone             String?    @unique
  password          String
  avatar            String?
  status            UserStatus @default(PENDING_VERIFICATION)
  emailVerified     Boolean    @default(false)
  phoneVerified     Boolean    @default(false)
  twoFactorEnabled  Boolean    @default(false)
  twoFactorSecret   String?
  lastLoginAt       DateTime?
  lastLoginIp       String?
  passwordChangedAt DateTime?
  refreshTokenHash  String?
  failedLoginCount  Int        @default(0)
  lockedUntil       DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  deletedAt         DateTime?

  userRoles         UserRole[]
  auditLogs         AuditLog[]
  inventoryLogs     InventoryLog[]
  purchaseOrders    PurchaseOrder[]
  salesOrders       SalesOrder[]
  stockTransfers    StockTransfer[]
  loginHistory      LoginHistory[]
  createdProducts   Product[]       @relation("ProductCreatedBy")
  updatedProducts   Product[]       @relation("ProductUpdatedBy")
  alerts            Alert[]
  rewardPoints      RewardPoint[]
  referredReferrals Referral[]      @relation("Referred")
  referrerReferrals Referral[]      @relation("Referrer")
  notifications     Notification[]
  wallet            Wallet?

  supportTicketsCustomer    SupportTicket[]   @relation("SupportTicketCustomer")
  supportTicketsAssigned    SupportTicket[]   @relation("SupportTicketStaff")
  approvalRequestsRequested ApprovalRequest[] @relation("ApprovalRequestedBy")
  approvalRequestsAssigned  ApprovalRequest[] @relation("ApprovalAssignedTo")
  staffTasksAssigned        StaffTask[]       @relation("TaskAssignedTo")
  staffTasksCreated         StaffTask[]       @relation("TaskCreatedBy")

  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  displayName String
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  module      String
  action      String
  name        String
  description String?
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]

  @@unique([module, action])
  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model LoginHistory {
  id         String   @id @default(uuid())
  userId     String
  ipAddress  String?
  userAgent  String?
  device     String?
  browser    String?
  os         String?
  location   String?
  success    Boolean
  failReason String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("login_history")
}

// ============================================================
// CATEGORIES
// ============================================================

model Category {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  image       String?
  parentId    String?
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  parent        Category?     @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children      Category[]    @relation("CategoryHierarchy")
  products      Product[]
  subcategories Subcategory[]

  @@map("categories")
}

model Subcategory {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  image       String?
  categoryId  String
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category Category  @relation(fields: [categoryId], references: [id])
  products Product[]

  @@map("subcategories")
}

// ============================================================
// BRANDS
// ============================================================

model Brand {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  logo        String?
  website     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@map("brands")
}

// ============================================================
// COLLECTIONS & TAGS
// ============================================================

model Collection {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  image       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products ProductCollection[]

  @@map("collections")
}

model Tag {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())

  products ProductTag[]

  @@map("tags")
}

// ============================================================
// SUPPLIERS
// ============================================================

model Supplier {
  id             String    @id @default(uuid())
  code           String    @unique
  name           String
  email          String?
  phone          String?
  alternatePhone String?
  contactPerson  String?
  website        String?
  gstNumber      String?
  panNumber      String?
  address        String?
  city           String?
  state          String?
  country        String?
  pincode        String?
  bankName       String?
  bankAccount    String?
  bankIfsc       String?
  creditLimit    Decimal?  @db.Decimal(15, 2)
  creditDays     Int?
  isActive       Boolean   @default(true)
  status         SupplierStatus @default(APPROVED)
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  products         Product[]
  purchaseOrders   PurchaseOrder[]
  supplierPayments SupplierPayment[]

  @@map("suppliers")
}

// ============================================================
// WAREHOUSES
// ============================================================

model Warehouse {
  id              String    @id @default(uuid())
  code            String    @unique
  name            String
  description     String?
  type            String?
  managerName     String?
  managerEmail    String?
  managerPhone    String?
  address         String?
  city            String?
  state           String?
  country         String?
  pincode         String?
  latitude        Float?
  longitude       Float?
  totalCapacity   Float?
  currentCapacity Float?    @default(0)
  isActive        Boolean   @default(true)
  isDefault       Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  zones            WarehouseZone[]
  inventory        Inventory[]
  transfersFrom    StockTransfer[]     @relation("TransferFrom")
  transfersTo      StockTransfer[]     @relation("TransferTo")
  purchaseReceipts PurchaseOrderItem[]

  @@map("warehouses")
}

model WarehouseZone {
  id          String   @id @default(uuid())
  warehouseId String
  code        String
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  warehouse Warehouse       @relation(fields: [warehouseId], references: [id])
  racks     WarehouseRack[]

  @@unique([warehouseId, code])
  @@map("warehouse_zones")
}

model WarehouseRack {
  id          String   @id @default(uuid())
  zoneId      String
  code        String
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  zone    WarehouseZone    @relation(fields: [zoneId], references: [id])
  shelves WarehouseShelf[]

  @@unique([zoneId, code])
  @@map("warehouse_racks")
}

model WarehouseShelf {
  id          String   @id @default(uuid())
  rackId      String
  code        String
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  rack WarehouseRack  @relation(fields: [rackId], references: [id])
  bins WarehouseBin[]

  @@unique([rackId, code])
  @@map("warehouse_shelves")
}

model WarehouseBin {
  id          String   @id @default(uuid())
  shelfId     String
  code        String
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  shelf WarehouseShelf @relation(fields: [shelfId], references: [id])

  @@unique([shelfId, code])
  @@map("warehouse_bins")
}

// ============================================================
// PRODUCTS
// ============================================================

model Product {
  id               String        @id @default(uuid())
  sku              String        @unique
  barcode          String?       @unique
  qrCode           String?
  name             String
  slug             String        @unique
  shortDescription String?
  longDescription  String?
  brandId          String?
  categoryId       String?
  subcategoryId    String?
  supplierId       String?
  productType      ProductType   @default(SIMPLE)
  hsnCode          String?
  gstPercent       Decimal?      @db.Decimal(5, 2)
  manufacturer     String?
  countryOfOrigin  String?
  warranty         String?
  weight           Decimal?      @db.Decimal(10, 3)
  weightUnit       String?       @default("kg")
  length           Decimal?      @db.Decimal(10, 2)
  width            Decimal?      @db.Decimal(10, 2)
  height           Decimal?      @db.Decimal(10, 2)
  dimensionUnit    String?       @default("cm")
  material         String?
  color            String?
  size             String?
  thumbnail        String?
  status           ProductStatus @default(DRAFT)
  isFeatured       Boolean       @default(false)
  isTrending       Boolean       @default(false)
  isNewArrival     Boolean       @default(false)
  isBestSeller     Boolean       @default(false)
  isActive         Boolean       @default(true)
  mrp              Decimal       @db.Decimal(15, 2)
  costPrice        Decimal?      @db.Decimal(15, 2)
  sellingPrice     Decimal       @db.Decimal(15, 2)
  discountPrice    Decimal?      @db.Decimal(15, 2)
  metaTitle        String?
  metaDescription  String?
  notes            String?
  createdById      String?
  updatedById      String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  deletedAt        DateTime?

  brand       Brand?       @relation(fields: [brandId], references: [id])
  category    Category?    @relation(fields: [categoryId], references: [id])
  subcategory Subcategory? @relation(fields: [subcategoryId], references: [id])
  supplier    Supplier?    @relation(fields: [supplierId], references: [id])
  createdBy   User?        @relation("ProductCreatedBy", fields: [createdById], references: [id])
  updatedBy   User?        @relation("ProductUpdatedBy", fields: [updatedById], references: [id])

  variants      ProductVariant[]
  images        ProductImage[]
  videos        ProductVideo[]
  tags          ProductTag[]
  collections   ProductCollection[]
  inventory     Inventory[]
  inventoryLogs InventoryLog[]
  purchaseItems PurchaseOrderItem[]
  salesItems    SalesOrderItem[]
  alerts        Alert[]

  @@index([sku])
  @@index([barcode])
  @@index([categoryId])
  @@index([brandId])
  @@index([status])
  @@index([isActive])
  @@map("products")
}

model ProductVariant {
  id            String   @id @default(uuid())
  productId     String
  sku           String   @unique
  barcode       String?  @unique
  name          String
  color         String?
  size          String?
  weight        Decimal? @db.Decimal(10, 3)
  ram           String?
  storage       String?
  model         String?
  edition       String?
  package       String?
  mrp           Decimal  @db.Decimal(15, 2)
  costPrice     Decimal? @db.Decimal(15, 2)
  sellingPrice  Decimal  @db.Decimal(15, 2)
  discountPrice Decimal? @db.Decimal(15, 2)
  image         String?
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  product   Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventory Inventory[]

  @@index([productId])
  @@map("product_variants")
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  url       String
  alt       String?
  sortOrder Int      @default(0)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model ProductVideo {
  id        String   @id @default(uuid())
  productId String
  url       String
  title     String?
  thumbnail String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_videos")
}

model ProductTag {
  productId String
  tagId     String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
  @@map("product_tags")
}

model ProductCollection {
  productId    String
  collectionId String

  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([productId, collectionId])
  @@map("product_collections")
}

// ============================================================
// INVENTORY
// ============================================================

model Inventory {
  id                String   @id @default(uuid())
  productId         String
  variantId         String?
  warehouseId       String
  currentStock      Int      @default(0)
  reservedStock     Int      @default(0)
  availableStock    Int      @default(0)
  incomingStock     Int      @default(0)
  outgoingStock     Int      @default(0)
  damagedStock      Int      @default(0)
  returnedStock     Int      @default(0)
  expiredStock      Int      @default(0)
  lostStock         Int      @default(0)
  minStockLevel     Int      @default(0)
  maxStockLevel     Int?
  reorderLevel      Int      @default(0)
  safetyStock       Int      @default(0)
  backorderQuantity Int      @default(0)
  stockUnit         String   @default("pcs")
  zoneCode          String?
  rackCode          String?
  shelfCode         String?
  binCode           String?
  costPrice         Decimal? @db.Decimal(15, 2)
  sellingPrice      Decimal? @db.Decimal(15, 2)
  mrp               Decimal? @db.Decimal(15, 2)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  product   Product          @relation(fields: [productId], references: [id])
  variant   ProductVariant?  @relation(fields: [variantId], references: [id])
  warehouse Warehouse        @relation(fields: [warehouseId], references: [id])
  batches   InventoryBatch[]

  @@unique([productId, variantId, warehouseId])
  @@index([productId])
  @@index([warehouseId])
  @@index([availableStock])
  @@map("inventory")
}

model InventoryBatch {
  id                String    @id @default(uuid())
  inventoryId       String
  batchNumber       String?
  lotNumber         String?
  serialNumber      String?
  quantity          Int
  remainingQuantity Int
  manufacturingDate DateTime?
  expiryDate        DateTime?
  costPrice         Decimal?  @db.Decimal(15, 2)
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  inventory Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  @@index([inventoryId])
  @@index([expiryDate])
  @@map("inventory_batches")
}

model InventoryLog {
  id             String             @id @default(uuid())
  productId      String
  variantId      String?
  warehouseId    String?
  operationType  StockOperationType
  beforeQuantity Int
  afterQuantity  Int
  quantity       Int
  reason         String?
  referenceType  String?
  referenceId    String?
  batchNumber    String?
  serialNumber   String?
  unitCost       Decimal?           @db.Decimal(15, 2)
  totalCost      Decimal?           @db.Decimal(15, 2)
  userId         String?
  ipAddress      String?
  device         String?
  userAgent      String?
  notes          String?
  createdAt      DateTime           @default(now())

  product Product @relation(fields: [productId], references: [id])
  user    User?   @relation(fields: [userId], references: [id])

  @@index([productId])
  @@index([warehouseId])
  @@index([operationType])
  @@index([createdAt])
  @@map("inventory_logs")
}

// ============================================================
// PURCHASE MANAGEMENT
// ============================================================

model PurchaseOrder {
  id             String              @id @default(uuid())
  poNumber       String              @unique
  supplierId     String
  status         PurchaseOrderStatus @default(DRAFT)
  orderDate      DateTime            @default(now())
  expectedDate   DateTime?
  receivedDate   DateTime?
  subtotal       Decimal             @default(0) @db.Decimal(15, 2)
  discountAmount Decimal             @default(0) @db.Decimal(15, 2)
  taxAmount      Decimal             @default(0) @db.Decimal(15, 2)
  shippingAmount Decimal             @default(0) @db.Decimal(15, 2)
  totalAmount    Decimal             @default(0) @db.Decimal(15, 2)
  paidAmount     Decimal             @default(0) @db.Decimal(15, 2)
  dueAmount      Decimal             @default(0) @db.Decimal(15, 2)
  paymentStatus  PaymentStatus       @default(PENDING)
  paymentMethod  PaymentMethod?
  paymentTerms   String?
  currency       String              @default("INR")
  notes          String?
  internalNotes  String?
  createdById    String?
  approvedById   String?
  approvedAt     DateTime?
  warehouseId    String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  deletedAt      DateTime?

  supplier  Supplier            @relation(fields: [supplierId], references: [id])
  createdBy User?               @relation(fields: [createdById], references: [id])
  items     PurchaseOrderItem[]
  invoices  PurchaseInvoice[]
  payments  SupplierPayment[]
  returns   PurchaseReturn[]

  @@index([supplierId])
  @@index([status])
  @@index([orderDate])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id               String    @id @default(uuid())
  purchaseOrderId  String
  productId        String
  variantId        String?
  warehouseId      String?
  orderedQuantity  Int
  receivedQuantity Int       @default(0)
  pendingQuantity  Int
  returnedQuantity Int       @default(0)
  unitCost         Decimal   @db.Decimal(15, 2)
  totalCost        Decimal   @db.Decimal(15, 2)
  taxPercent       Decimal?  @db.Decimal(5, 2)
  taxAmount        Decimal?  @db.Decimal(15, 2)
  discountPercent  Decimal?  @db.Decimal(5, 2)
  discountAmount   Decimal?  @db.Decimal(15, 2)
  batchNumber      String?
  lotNumber        String?
  expiryDate       DateTime?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])
  warehouse     Warehouse?    @relation(fields: [warehouseId], references: [id])

  @@index([purchaseOrderId])
  @@map("purchase_order_items")
}

model PurchaseInvoice {
  id              String        @id @default(uuid())
  purchaseOrderId String
  invoiceNumber   String        @unique
  invoiceDate     DateTime
  dueDate         DateTime?
  amount          Decimal       @db.Decimal(15, 2)
  taxAmount       Decimal?      @db.Decimal(15, 2)
  totalAmount     Decimal       @db.Decimal(15, 2)
  paidAmount      Decimal       @default(0) @db.Decimal(15, 2)
  status          PaymentStatus @default(PENDING)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])

  @@map("purchase_invoices")
}

model PurchaseReturn {
  id              String       @id @default(uuid())
  purchaseOrderId String
  returnNumber    String       @unique
  reason          String?
  returnDate      DateTime     @default(now())
  totalAmount     Decimal      @db.Decimal(15, 2)
  status          ReturnStatus @default(PENDING)
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  purchaseOrder PurchaseOrder        @relation(fields: [purchaseOrderId], references: [id])
  items         PurchaseReturnItem[]

  @@map("purchase_returns")
}

model PurchaseReturnItem {
  id               String   @id @default(uuid())
  purchaseReturnId String
  productId        String
  variantId        String?
  quantity         Int
  unitCost         Decimal  @db.Decimal(15, 2)
  totalCost        Decimal  @db.Decimal(15, 2)
  reason           String?
  createdAt        DateTime @default(now())

  purchaseReturn PurchaseReturn @relation(fields: [purchaseReturnId], references: [id], onDelete: Cascade)

  @@map("purchase_return_items")
}

model SupplierPayment {
  id              String        @id @default(uuid())
  supplierId      String
  purchaseOrderId String?
  paymentNumber   String        @unique
  amount          Decimal       @db.Decimal(15, 2)
  paymentMethod   PaymentMethod
  paymentDate     DateTime
  referenceNumber String?
  notes           String?
  createdAt       DateTime      @default(now())

  supplier      Supplier       @relation(fields: [supplierId], references: [id])
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])

  @@map("supplier_payments")
}

// ============================================================
// SALES MANAGEMENT
// ============================================================

model SalesOrder {
  id              String           @id @default(uuid())
  orderNumber     String           @unique
  customerId      String?
  customerName    String?
  customerEmail   String?
  customerPhone   String?
  status          SalesOrderStatus @default(PENDING)
  orderDate       DateTime         @default(now())
  confirmedAt     DateTime?
  packedAt        DateTime?
  dispatchedAt    DateTime?
  deliveredAt     DateTime?
  cancelledAt     DateTime?
  subtotal        Decimal          @default(0) @db.Decimal(15, 2)
  discountAmount  Decimal          @default(0) @db.Decimal(15, 2)
  taxAmount       Decimal          @default(0) @db.Decimal(15, 2)
  shippingAmount  Decimal          @default(0) @db.Decimal(15, 2)
  totalAmount     Decimal          @default(0) @db.Decimal(15, 2)
  paidAmount      Decimal          @default(0) @db.Decimal(15, 2)
  dueAmount       Decimal          @default(0) @db.Decimal(15, 2)
  paymentStatus   PaymentStatus    @default(PENDING)
  paymentMethod   PaymentMethod?
  shippingAddress String?
  billingAddress  String?
  courierName     String?
  trackingNumber  String?
  notes           String?
  cancelReason    String?
  createdById     String?
  warehouseId     String?
  currency        String           @default("INR")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?

  createdBy User?            @relation(fields: [createdById], references: [id])
  items     SalesOrderItem[]
  invoices  SalesInvoice[]
  returns   SalesReturn[]
  refunds   Refund[]

  @@index([customerId])
  @@index([status])
  @@index([orderDate])
  @@map("sales_orders")
}

model SalesOrderItem {
  id             String   @id @default(uuid())
  salesOrderId   String
  productId      String
  variantId      String?
  warehouseId    String?
  quantity       Int
  unitPrice      Decimal  @db.Decimal(15, 2)
  mrp            Decimal? @db.Decimal(15, 2)
  discountAmount Decimal? @db.Decimal(15, 2)
  taxPercent     Decimal? @db.Decimal(5, 2)
  taxAmount      Decimal? @db.Decimal(15, 2)
  totalAmount    Decimal  @db.Decimal(15, 2)
  returnedQty    Int      @default(0)
  batchNumber    String?
  notes          String?
  createdAt      DateTime @default(now())

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id])

  @@index([salesOrderId])
  @@map("sales_order_items")
}

model SalesInvoice {
  id            String        @id @default(uuid())
  salesOrderId  String
  invoiceNumber String        @unique
  invoiceDate   DateTime
  dueDate       DateTime?
  subtotal      Decimal       @db.Decimal(15, 2)
  taxAmount     Decimal       @default(0) @db.Decimal(15, 2)
  totalAmount   Decimal       @db.Decimal(15, 2)
  status        PaymentStatus @default(PENDING)
  notes         String?
  createdAt     DateTime      @default(now())

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id])

  @@map("sales_invoices")
}

model SalesReturn {
  id           String       @id @default(uuid())
  salesOrderId String
  returnNumber String       @unique
  reason       String?
  returnDate   DateTime     @default(now())
  totalAmount  Decimal      @db.Decimal(15, 2)
  refundAmount Decimal?     @db.Decimal(15, 2)
  status       ReturnStatus @default(PENDING)
  returnType   ReturnType   @default(CUSTOMER_RETURN)
  notes        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  salesOrder SalesOrder        @relation(fields: [salesOrderId], references: [id])
  items      SalesReturnItem[]
  refunds    Refund[]

  @@map("sales_returns")
}

model SalesReturnItem {
  id            String   @id @default(uuid())
  salesReturnId String
  productId     String
  variantId     String?
  quantity      Int
  unitPrice     Decimal  @db.Decimal(15, 2)
  totalAmount   Decimal  @db.Decimal(15, 2)
  reason        String?
  condition     String?
  createdAt     DateTime @default(now())

  salesReturn SalesReturn @relation(fields: [salesReturnId], references: [id], onDelete: Cascade)

  @@map("sales_return_items")
}

// ============================================================
// STOCK TRANSFERS
// ============================================================

model StockTransfer {
  id              String         @id @default(uuid())
  transferNumber  String         @unique
  fromWarehouseId String
  toWarehouseId   String
  status          TransferStatus @default(DRAFT)
  reason          String?
  notes           String?
  transferDate    DateTime       @default(now())
  completedAt     DateTime?
  createdById     String?
  approvedById    String?
  approvedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  fromWarehouse Warehouse           @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse           @relation("TransferTo", fields: [toWarehouseId], references: [id])
  createdBy     User?               @relation(fields: [createdById], references: [id])
  items         StockTransferItem[]

  @@index([fromWarehouseId])
  @@index([toWarehouseId])
  @@index([status])
  @@map("stock_transfers")
}

model StockTransferItem {
  id             String   @id @default(uuid())
  transferId     String
  productId      String
  variantId      String?
  requestedQty   Int
  transferredQty Int      @default(0)
  unitCost       Decimal? @db.Decimal(15, 2)
  batchNumber    String?
  notes          String?
  createdAt      DateTime @default(now())

  transfer StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@map("stock_transfer_items")
}

// ============================================================
// ALERTS
// ============================================================

model Alert {
  id           String      @id @default(uuid())
  type         AlertType
  status       AlertStatus @default(ACTIVE)
  productId    String?
  warehouseId  String?
  title        String
  message      String
  severity     String      @default("medium")
  metadata     Json?
  resolvedAt   DateTime?
  resolvedById String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  product    Product? @relation(fields: [productId], references: [id])
  resolvedBy User?    @relation(fields: [resolvedById], references: [id])

  @@index([type])
  @@index([status])
  @@index([productId])
  @@map("alerts")
}

// ============================================================
// AUDIT LOGS
// ============================================================

model AuditLog {
  id           String      @id @default(uuid())
  userId       String?
  userEmail    String?
  userRole     String?
  action       AuditAction
  module       String
  entityType   String?
  entityId     String?
  oldValues    Json?
  newValues    Json?
  description  String?
  ipAddress    String?
  userAgent    String?
  browser      String?
  os           String?
  device       String?
  location     String?
  status       String      @default("success")
  errorMessage String?
  createdAt    DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([module])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================
// SETTINGS
// ============================================================

model Setting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  type        String   @default("string")
  group       String?
  description String?
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("settings")
}

// ============================================================
// CMS
// ============================================================

model CmsPage {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  content     String   @db.Text
  isPublished Boolean  @default(false)
  metaTitle   String?
  metaDesc    String?
  authorId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("cms_pages")
}

model CmsBlog {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  content     String   @db.Text
  image       String?
  isPublished Boolean  @default(false)
  authorId    String?
  tags        String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("cms_blogs")
}

model CmsBanner {
  id        String   @id @default(uuid())
  title     String
  imageUrl  String
  linkUrl   String?
  position  String   @default("homepage_hero")
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("cms_banners")
}

model CmsTestimonial {
  id           String   @id @default(uuid())
  customerName String
  company      String?
  content      String
  rating       Int      @default(5)
  avatarUrl    String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@map("cms_testimonials")
}

model CmsFaq {
  id        String   @id @default(uuid())
  question  String
  answer    String   @db.Text
  category  String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@map("cms_faqs")
}

// ============================================================
// MARKETING
// ============================================================

model MarketingCampaign {
  id           String    @id @default(uuid())
  name         String
  type         String    @default("EMAIL") // EMAIL, SMS, WHATSAPP, PUSH
  status       String    @default("DRAFT") // DRAFT, SCHEDULED, SENT, CANCELLED
  subject      String?
  content      String    @db.Text
  audienceId   String?
  scheduledFor DateTime?
  sentAt       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("marketing_campaigns")
}

model MarketingAudience {
  id          String   @id @default(uuid())
  name        String
  description String?
  criteria    Json? // e.g. { "lastPurchaseDays": 30 }
  createdAt   DateTime @default(now())

  @@map("marketing_audiences")
}

// ============================================================
// COUPONS
// ============================================================

model Coupon {
  id            String    @id @default(uuid())
  code          String    @unique
  description   String?
  discountType  String    @default("PERCENTAGE") // PERCENTAGE, FIXED_AMOUNT, FREE_SHIPPING
  discountValue Decimal   @db.Decimal(15, 2)
  minPurchase   Decimal?  @db.Decimal(15, 2)
  maxDiscount   Decimal?  @db.Decimal(15, 2)
  startDate     DateTime?
  endDate       DateTime?
  usageLimit    Int?
  usageCount    Int       @default(0)
  perUserLimit  Int?      @default(1)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  usages CouponUsage[]

  @@map("coupons")
}

model CouponUsage {
  id          String   @id @default(uuid())
  couponId    String
  userId      String?
  orderId     String?
  discountAmt Decimal  @db.Decimal(15, 2)
  usedAt      DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id])

  @@index([couponId])
  @@map("coupon_usages")
}

// ============================================================
// LOYALTY
// ============================================================

model RewardPoint {
  id          String   @id @default(uuid())
  userId      String
  points      Int
  type        String   @default("EARN") // EARN, REDEEM
  source      String   @default("ORDER") // ORDER, REFERRAL, SIGNUP, MANUAL
  referenceId String?
  description String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("reward_points")
}

// ============================================================
// REFERRAL
// ============================================================

model Referral {
  id             String   @id @default(uuid())
  referrerId     String
  referredEmail  String
  referredUserId String? // Once they sign up
  status         String   @default("PENDING") // PENDING, COMPLETED
  rewardPoints   Int      @default(0)
  createdAt      DateTime @default(now())

  referrer     User  @relation("Referrer", fields: [referrerId], references: [id])
  referredUser User? @relation("Referred", fields: [referredUserId], references: [id])

  @@map("referrals")
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id      String   @id @default(uuid())
  userId  String?
  type    String   @default("SYSTEM") // SYSTEM, EMAIL, SMS, PUSH, WHATSAPP
  title   String
  message String   @db.Text
  isRead  Boolean  @default(false)
  sentAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("notifications")
}

// ============================================================
// WALLET
// ============================================================

enum WalletTransactionType {
  CREDIT
  DEBIT
}

model Wallet {
  id        String   @id @default(uuid())
  userId    String   @unique
  balance   Decimal  @default(0) @db.Decimal(15, 2)
  currency  String   @default("INR")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@map("wallets")
}

model WalletTransaction {
  id          String                @id @default(uuid())
  walletId    String
  amount      Decimal               @db.Decimal(15, 2)
  type        WalletTransactionType
  source      String                // REFUND, PAYMENT, MANUAL, REVERSAL, LOYALTY
  referenceId String?
  description String?
  createdAt   DateTime              @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@map("wallet_transactions")
}

// ============================================================
// REFUNDS
// ============================================================

enum RefundStatus {
  PENDING
  APPROVED
  REJECTED
  PROCESSED
  FAILED
}

model Refund {
  id               String       @id @default(uuid())
  refundNumber     String       @unique
  salesOrderId     String?
  salesReturnId    String?
  amount           Decimal      @db.Decimal(15, 2)
  status           RefundStatus @default(PENDING)
  paymentMethod    PaymentMethod?
  gatewayReference String?
  reason           String?
  notes            String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  salesOrder  SalesOrder?  @relation(fields: [salesOrderId], references: [id])
  salesReturn SalesReturn? @relation(fields: [salesReturnId], references: [id])

  @@index([salesOrderId])
  @@index([salesReturnId])
  @@map("refunds")
}

// ============================================================
// GST & TAX RECORDS
// ============================================================

enum TaxTransactionType {
  SALES
  PURCHASE
  RETURN
  REFUND
}

model TaxRecord {
  id              String             @id @default(uuid())
  transactionType TaxTransactionType
  referenceId     String             // salesOrderId / purchaseOrderId / salesReturnId / purchaseReturnId / refundId
  hsnCode         String?
  taxableAmount   Decimal            @db.Decimal(15, 2)
  gstPercent      Decimal            @db.Decimal(5, 2)
  cgstAmount      Decimal            @db.Decimal(15, 2)
  sgstAmount      Decimal            @db.Decimal(15, 2)
  igstAmount      Decimal            @db.Decimal(15, 2)
  totalTaxAmount  Decimal            @db.Decimal(15, 2)
  state           String?            // State code/name to identify interstate (IGST) vs intrastate (CGST+SGST)
  createdAt       DateTime           @default(now())

  @@index([transactionType, referenceId])
  @@map("tax_records")
}

// ============================================================
// ACCOUNTING (DOUBLE ENTRY)
// ============================================================

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum EntryType {
  DEBIT
  CREDIT
}

model Account {
  id          String      @id @default(uuid())
  code        String      @unique // e.g. "1000", "1200", "2000"
  name        String
  type        AccountType
  balance     Decimal     @default(0) @db.Decimal(15, 2)
  description String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  journalEntries JournalEntry[]

  @@map("accounts")
}

model TransactionJournal {
  id          String   @id @default(uuid())
  reference   String?  // e.g. "INV-1002", "PO-2005"
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  entries JournalEntry[]

  @@map("transaction_journals")
}

model JournalEntry {
  id        String    @id @default(uuid())
  journalId String
  accountId String
  type      EntryType
  amount    Decimal   @db.Decimal(15, 2)
  createdAt DateTime  @default(now())

  journal TransactionJournal @relation(fields: [journalId], references: [id], onDelete: Cascade)
  account Account            @relation(fields: [accountId], references: [id])

  @@index([journalId])
  @@index([accountId])
  @@map("journal_entries")
}

// ============================================================
// PAYMENT RECONCILIATION
// ============================================================

enum ReconciliationStatus {
  UNRECONCILED
  RECONCILED
  PARTIALLY_RECONCILED
  DISCREPANCY
}

model PaymentReconciliation {
  id             String               @id @default(uuid())
  paymentRef     String               @unique // Gateway reference, UPI reference, cheque number, etc.
  amount         Decimal              @db.Decimal(15, 2)
  paymentDate    DateTime
  status         ReconciliationStatus @default(UNRECONCILED)
  matchedOrderId String?              // salesOrderId or purchaseOrderId
  matchedType    String?              // "SALES" or "PURCHASE"
  discrepancyAmt Decimal?             @db.Decimal(15, 2)
  notes          String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([status])
  @@map("payment_reconciliations")
}

// ============================================================
// PHASE 4: ENTERPRISE BUSINESS PLATFORM
// ============================================================

enum SupplierStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

model Store {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  address   String?
  phone     String?
  email     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("stores")
}

model SupportTicket {
  id              String         @id @default(uuid())
  ticketNumber    String         @unique
  customerId      String?
  title           String
  description     String
  status          TicketStatus   @default(OPEN)
  priority        TicketPriority @default(MEDIUM)
  assignedStaffId String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  customer        User?          @relation("SupportTicketCustomer", fields: [customerId], references: [id])
  assignedStaff   User?          @relation("SupportTicketStaff", fields: [assignedStaffId], references: [id])

  @@index([status])
  @@index([customerId])
  @@index([assignedStaffId])
  @@map("support_tickets")
}

model ApprovalRequest {
  id                 String         @id @default(uuid())
  entityType         String
  entityId           String
  requestedById      String
  assignedApproverId String
  status             ApprovalStatus @default(PENDING)
  comments           String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  requestedBy      User           @relation("ApprovalRequestedBy", fields: [requestedById], references: [id])
  assignedApprover User           @relation("ApprovalAssignedTo", fields: [assignedApproverId], references: [id])

  @@index([status])
  @@index([entityType, entityId])
  @@map("approval_requests")
}

model StaffTask {
  id           String       @id @default(uuid())
  title        String
  description  String?
  status       TaskStatus   @default(PENDING)
  priority     TaskPriority @default(MEDIUM)
  assignedToId String?
  createdById  String?
  dueDate      DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  assignedTo   User?        @relation("TaskAssignedTo", fields: [assignedToId], references: [id])
  createdBy    User?        @relation("TaskCreatedBy", fields: [createdById], references: [id])

  @@index([status])
  @@index([assignedToId])
  @@map("staff_tasks")
}

